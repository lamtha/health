{
  "name": "health",
  "productName": "Health",
  "version": "0.1.0",
  "description": "Local-first personal health dashboard — unify lab reports, chart trends, own your data.",
  "author": "Paul <pwidden@gmail.com>",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=22"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:api": "vitest run --project api",
    "test:smoke": "vitest run --project smoke",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/apply-seeds.ts",
    "db:backfill-canonical": "tsx scripts/backfill-canonical.ts",
    "db:studio": "drizzle-kit studio",
    "re-extract": "NODE_OPTIONS=--conditions=react-server tsx scripts/re-extract-all.ts",
    "bulk-map": "NODE_OPTIONS=--conditions=react-server tsx scripts/bulk-map-canonical.ts",
    "app:build-main": "tsc --project electron/tsconfig.json",
    "app:dev": "pnpm app:build-main && electron .",
    "app:rebuild-sys": "pnpm rebuild better-sqlite3",
    "app:rebuild-electron": "rm -rf node_modules/better-sqlite3/build && electron-rebuild --only better-sqlite3 --force",
    "app:build": "pnpm app:rebuild-sys && pnpm app:build-main && pnpm build && pnpm app:rebuild-electron && electron-builder --mac && pnpm app:rebuild-sys"
  },
  "build": {
    "appId": "com.lamthalabs.health",
    "productName": "Health",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "electron/main.js",
      "!electron/main.ts",
      "!electron/tsconfig.json",
      "!app/**/*.ts",
      "!app/**/*.tsx",
      "!components/**/*.ts",
      "!components/**/*.tsx",
      "!lib/**/*.ts",
      "!db/**/*.ts",
      "!drizzle.config.ts",
      "!dist/**",
      "!data/**",
      "!uploads/**",
      "!design/**",
      "!scripts/**",
      "!**/*.md",
      "!.env*",
      "!.git*",
      "!.claude/**",
      "!.vscode/**"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "target": {
        "target": "dir",
        "arch": [
          "arm64"
        ]
      },
      "category": "public.app-category.medical",
      "identity": null
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "shadcn": "^4.3.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@react-pdf/renderer": "^4.5.1",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "^15.5.15",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}
