{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".",
    "rootDir": ".",
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["main.ts", "validate-key.ts", "logs.ts", "mask-key.ts"],
  "exclude": ["main.js", "validate-key.js", "logs.js", "mask-key.js"]
}
